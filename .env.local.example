# Supabase — copie para .env.local e preencha com as chaves do seu projeto.
# Painel: https://supabase.com/dashboard  ->  Project Settings -> API

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave "anon public" — pode ir para o browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" — SECRETA, NUNCA exponha no cliente.
# Usada só nos route handlers (RSVP público e import da planilha).
SUPABASE_SERVICE_ROLE_KEY=

# (Opcional) URL pública do site, usada em metadados. Ex.: https://brunaevictor.com
NEXT_PUBLIC_SITE_URL=
